<main class="flex-grow pt-32 pb-section-padding px-8">
  <div class="max-w-7xl mx-auto">
    <!-- Header Section -->
    <header class="mb-stack-lg">
      <h1 class="font-h1 text-h1 text-primary mb-2">Mis Citas</h1>
      <p class="font-body-lg text-body-lg text-on-surface-variant">Gestiona tus servicios reservados y tu historial de belleza.</p>
    </header>

    <div class="flex justify-end mb-8">
      <%= link_to new_appointment_path,
            class: "px-8 py-3 bg-primary text-on-primary rounded-full font-label-caps uppercase tracking-widest hover:scale-105 transition-transform flex items-center gap-2" do %>
        <span class="material-symbols-outlined text-sm">add</span>
        Agendar nueva cita
      <% end %>
    </div>

    <% if @appointments.empty? %>
      <div class="py-24 text-center flex flex-col items-center gap-6 border-2 border-dashed border-outline-variant/20 rounded-xl">
        <span class="material-symbols-outlined text-stone-200 text-6xl">calendar_today</span>
        <p class="font-h3 text-stone-400">No tienes citas agendadas</p>
        <%= link_to "Agendar una cita", new_appointment_path,
              class: "px-8 py-3 bg-primary text-on-primary rounded-full font-label-caps uppercase tracking-widest hover:scale-105 transition-transform" %>
      </div>
    <% else %>
      <!-- Appointments List -->
      <div class="flex-grow space-y-6">
        <% @appointments.each do |apt| %>
          <% is_cancelled = apt.status == "cancelled" || apt.status == "completed" %>
          <div class="<%= is_cancelled ? 'bg-stone-50/50 opacity-70' : 'bg-white hover:shadow-lg hover:shadow-amber-900/5' %> p-8 rounded-xl flex flex-col md:flex-row justify-between items-center gap-6 border border-stone-100 transition-all duration-300">
            <div class="flex items-center gap-8 w-full md:w-auto">
              <div class="space-y-1">
                <!-- Status Badge -->
                <div class="flex items-center gap-3 mb-2">
                  <% badge_class = case apt.status
                     when "pending"   then "bg-amber-100 text-amber-800"
                     when "confirmed" then "bg-green-100 text-green-800"
                     when "cancelled" then "bg-stone-200 text-stone-600"
                     when "completed" then "bg-blue-100 text-blue-800"
                     else "bg-stone-100 text-stone-600"
                     end %>
                  <% badge_label = case apt.status
                     when "pending"   then "Pendiente"
                     when "confirmed" then "Confirmada"
                     when "cancelled" then "Cancelada"
                     when "completed" then "Completada"
                     else apt.status.capitalize
                     end %>
                  <span class="px-3 py-1 <%= badge_class %> text-[10px] font-bold uppercase tracking-widest rounded-full"><%= badge_label %></span>
                </div>

                <h4 class="font-h3 text-h3 <%= is_cancelled ? 'text-stone-400 line-through' : 'text-primary' %>">
                  <%= apt.service.name %>
                </h4>

                <div class="flex flex-col gap-1 <%= is_cancelled ? 'text-stone-400 line-through' : 'text-on-surface-variant' %> font-body-sm">
                  <span class="flex items-center gap-2">
                    <span class="material-symbols-outlined text-sm">calendar_today</span>
                    <%= l(apt.starts_at, format: :long) %>
                  </span>
                  <% if apt.respond_to?(:stylist) && apt.stylist.present? %>
                    <span class="flex items-center gap-2">
                      <span class="material-symbols-outlined text-sm">person_pin</span>
                      Estilista: <%= apt.stylist.respond_to?(:full_name) ? apt.stylist.full_name : apt.stylist.user.email %>
                    </span>
                  <% end %>
                </div>
              </div>
            </div>

            <div class="flex items-center gap-4 w-full md:w-auto justify-end">
              <% if apt.status.in?(%w[pending confirmed]) %>
                <%= button_to cancel_appointment_path(apt), method: :post,
                      class: "px-6 py-3 border border-amber-500 text-amber-700 font-label-caps uppercase text-xs rounded-sm hover:bg-amber-50 transition-all duration-300",
                      data: { turbo_confirm: "¿Cancelar esta cita?" } do %>
                  Cancelar
                <% end %>
              <% elsif is_cancelled %>
                <span class="px-6 py-3 text-stone-400 font-label-caps uppercase text-xs rounded-sm cursor-not-allowed">No Disponible</span>
              <% end %>
              <%= link_to appointment_path(apt), class: "px-6 py-3 bg-black text-white font-label-caps uppercase text-xs rounded-sm hover:scale-105 transition-all duration-300" do %>
                Detalles
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>
</main>
