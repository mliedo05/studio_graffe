<main class="pt-32 pb-section-padding px-8 max-w-screen-2xl mx-auto">
  <header class="mb-12">
    <h1 class="font-h1 text-h1 mb-2">Finalizar Compra</h1>
    <p class="font-body-md text-on-surface-variant">Complete sus detalles para confirmar su reserva y pedido.</p>
  </header>

  <%= form_with url: checkout_payment_path, method: :post do |f| %>
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 items-start">
      <!-- Left Column: Payment -->
      <div class="lg:col-span-7 space-y-12">
        <!-- Payment Method -->
        <section>
          <h3 class="font-h3 text-h3 mb-6 border-b border-outline-variant pb-2">Método de Pago</h3>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <label class="relative flex items-center p-6 border border-outline-variant rounded-xl cursor-pointer hover:bg-surface-container-low transition-colors group has-[:checked]:border-primary has-[:checked]:bg-surface-container">
              <%= f.radio_button :payment_method, "webpay", checked: true, class: "sr-only" %>
              <div class="flex flex-col">
                <span class="font-label-caps text-label-caps text-primary mb-1">Webpay</span>
                <span class="text-body-sm text-on-surface-variant">Débito y Transferencia</span>
              </div>
              <span class="material-symbols-outlined ml-auto text-primary">account_balance</span>
            </label>
            <label class="relative flex items-center p-6 border border-outline-variant rounded-xl cursor-pointer hover:bg-surface-container-low transition-colors group has-[:checked]:border-primary has-[:checked]:bg-surface-container">
              <%= f.radio_button :payment_method, "efectivo", class: "sr-only" %>
              <div class="flex flex-col">
                <span class="font-label-caps text-label-caps text-primary mb-1">Efectivo</span>
                <span class="text-body-sm text-on-surface-variant">Pago en el local</span>
              </div>
              <span class="material-symbols-outlined ml-auto text-primary">payments</span>
            </label>
          </div>
        </section>

        <!-- Billing Details -->
        <section>
          <h3 class="font-h3 text-h3 mb-6 border-b border-outline-variant pb-2">Detalles de Facturación</h3>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-6">
            <div class="relative border-b border-outline focus-within:border-primary transition-all pb-1">
              <label class="block font-label-caps text-label-caps text-on-surface-variant mb-1">Nombre Completo</label>
              <input class="w-full bg-transparent border-none p-0 focus:ring-0 font-body-md"
                     placeholder="<%= current_user.respond_to?(:full_name) ? current_user.full_name : current_user.email %>"
                     type="text" value="<%= current_user.respond_to?(:full_name) ? current_user.full_name : '' %>"/>
            </div>
            <div class="relative border-b border-outline focus-within:border-primary transition-all pb-1">
              <label class="block font-label-caps text-label-caps text-on-surface-variant mb-1">Email</label>
              <input class="w-full bg-transparent border-none p-0 focus:ring-0 font-body-md"
                     placeholder="<%= current_user.email %>"
                     type="email" value="<%= current_user.email %>" readonly/>
            </div>
            <div class="md:col-span-2 relative border-b border-outline focus-within:border-primary transition-all pb-1">
              <label class="block font-label-caps text-label-caps text-on-surface-variant mb-1">Notas del pedido (Opcional)</label>
              <%= f.text_area :notes, class: "w-full bg-transparent border-none p-0 focus:ring-0 font-body-md resize-none", rows: 2, placeholder: "Instrucciones de entrega, comentarios..." %>
            </div>
          </div>
        </section>
      </div>

      <!-- Right Column: Order Summary -->
      <aside class="lg:col-span-5 lg:sticky lg:top-32">
        <div class="bg-white border border-stone-100 rounded-xl p-8 shadow-sm">
          <h3 class="font-h3 text-h3 mb-8">Resumen del Pedido</h3>
          <div class="space-y-6 mb-8">
            <% @cart.order_items.each do |item| %>
              <div class="flex gap-4">
                <div class="w-20 h-20 bg-stone-100 rounded-lg overflow-hidden flex-shrink-0">
                  <% if item.product.respond_to?(:image_url) && item.product.image_url.present? %>
                    <img alt="<%= item.product.name %>" class="w-full h-full object-cover" src="<%= item.product.image_url %>"/>
                  <% else %>
                    <div class="w-full h-full flex items-center justify-center">
                      <span class="material-symbols-outlined text-stone-300">inventory_2</span>
                    </div>
                  <% end %>
                </div>
                <div class="flex-grow">
                  <p class="font-body-md font-medium"><%= item.product.name %></p>
                  <p class="font-body-sm text-on-surface-variant">Cantidad: <%= item.quantity %></p>
                  <p class="font-body-sm mt-1"><%= humanized_money_with_symbol(item.product.price * item.quantity) %></p>
                </div>
              </div>
            <% end %>
          </div>
          <div class="border-t border-stone-100 pt-6 space-y-3">
            <div class="flex justify-between text-on-surface-variant">
              <span class="font-body-md">Subtotal</span>
              <span class="font-body-md"><%= humanized_money_with_symbol(@cart.total) %></span>
            </div>
            <div class="flex justify-between pt-4 border-t border-stone-100">
              <span class="font-h3 text-h3">Total</span>
              <span class="font-h3 text-h3"><%= humanized_money_with_symbol(@cart.total) %></span>
            </div>
          </div>
          <%= f.submit "Confirmar pedido",
                class: "w-full mt-10 bg-primary text-on-primary py-5 rounded-lg font-label-caps text-label-caps hover:bg-stone-800 transition-all active:scale-[0.98] cursor-pointer uppercase tracking-widest" %>
          <p class="text-center mt-6 text-body-sm text-outline flex items-center justify-center gap-2">
            <span class="material-symbols-outlined text-[16px]">verified_user</span>
            Pago 100% Seguro y Encriptado
          </p>
        </div>

        <div class="mt-8 p-6 bg-amber-50/30 rounded-xl border border-amber-100/50">
          <div class="flex gap-4">
            <span class="material-symbols-outlined text-amber-600">info</span>
            <div>
              <p class="font-body-sm font-medium text-amber-900">Política de Cancelación</p>
              <p class="font-body-sm text-amber-800/70 mt-1">Cancela hasta 24 horas antes sin cargos adicionales para citas agendadas.</p>
            </div>
          </div>
        </div>
      </aside>
    </div>
  <% end %>
</main>
