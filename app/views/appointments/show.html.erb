<main class="flex-grow pt-32 pb-section-padding px-8">
  <div class="max-w-3xl mx-auto">
    <%= link_to appointments_path, class: "flex items-center gap-2 font-label-caps text-label-caps text-on-surface-variant hover:text-primary transition-colors uppercase tracking-widest mb-8" do %>
      <span class="material-symbols-outlined text-sm">arrow_back</span>
      Volver a mis citas
    <% end %>

    <% badge_class = case @appointment.status
       when "pending"   then "bg-amber-100 text-amber-800"
       when "confirmed" then "bg-green-100 text-green-800"
       when "cancelled" then "bg-stone-200 text-stone-600"
       when "completed" then "bg-blue-100 text-blue-800"
       else "bg-stone-100 text-stone-600"
       end %>
    <% badge_label = case @appointment.status
       when "pending"   then "Pendiente"
       when "confirmed" then "Confirmada"
       when "cancelled" then "Cancelada"
       when "completed" then "Completada"
       else @appointment.status.capitalize
       end %>

    <div class="bg-white p-10 rounded-xl border border-stone-100 shadow-sm">
      <div class="flex items-start justify-between mb-8">
        <div>
          <span class="px-3 py-1 <%= badge_class %> text-[10px] font-bold uppercase tracking-widest rounded-full"><%= badge_label %></span>
          <h1 class="font-h1 text-h1 text-primary mt-4"><%= @appointment.service.name %></h1>
        </div>
        <% if @appointment.status.in?(%w[pending confirmed]) %>
          <%= button_to cancel_appointment_path(@appointment), method: :post,
                class: "px-6 py-3 border border-amber-500 text-amber-700 font-label-caps uppercase text-xs rounded-sm hover:bg-amber-50 transition-all duration-300",
                data: { turbo_confirm: "¿Cancelar esta cita?" } do %>
            Cancelar cita
          <% end %>
        <% end %>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 border-t border-stone-100 pt-8">
        <div class="space-y-6">
          <div>
            <p class="font-label-caps text-[10px] text-stone-400 uppercase tracking-widest mb-1">Servicio</p>
            <p class="font-body-lg text-on-surface"><%= @appointment.service.name %></p>
          </div>

          <% if @appointment.respond_to?(:stylist) && @appointment.stylist.present? %>
            <div>
              <p class="font-label-caps text-[10px] text-stone-400 uppercase tracking-widest mb-1">Estilista</p>
              <p class="font-body-lg text-on-surface">
                <%= @appointment.stylist.respond_to?(:full_name) ? @appointment.stylist.full_name : @appointment.stylist.user.email %>
              </p>
            </div>
          <% end %>
        </div>

        <div class="space-y-6">
          <div>
            <p class="font-label-caps text-[10px] text-stone-400 uppercase tracking-widest mb-1">Fecha y Hora</p>
            <p class="font-body-lg text-on-surface"><%= l(@appointment.starts_at, format: :long) %></p>
          </div>

          <% if @appointment.notes.present? %>
            <div>
              <p class="font-label-caps text-[10px] text-stone-400 uppercase tracking-widest mb-1">Notas</p>
              <p class="font-body-md text-on-surface-variant"><%= @appointment.notes %></p>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</main>
