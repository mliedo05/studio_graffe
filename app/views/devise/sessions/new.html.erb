<% content_for :head do %>
  <style>
    .floating-label-input:focus-within label,
    .floating-label-input input:not(:placeholder-shown) + label {
      transform: translateY(-1.5rem) scale(0.85);
      color: #7e7576;
    }
    .floating-label-input label {
      transition: all 0.2s ease-out;
      pointer-events: none;
    }
  </style>
<% end %>

<div class="min-h-screen flex flex-col items-center justify-center p-gutter bg-background">
  <!-- Background decorative -->
  <div class="fixed inset-0 -z-10 pointer-events-none">
    <div class="absolute top-0 right-0 w-1/2 h-full bg-gradient-to-l from-amber-50/20 to-transparent"></div>
    <div class="absolute bottom-0 left-0 w-1/3 h-1/2 from-amber-100/10 via-transparent to-transparent"></div>
  </div>

  <main class="w-full max-w-[450px] mx-auto">
    <div class="bg-surface-container-lowest rounded-xl shadow-sm border border-outline-variant/30 overflow-hidden px-10 py-12 flex flex-col gap-10">
      <!-- Logo -->
      <div class="text-center">
        <h1 class="text-4xl font-serif italic tracking-widest text-primary mb-2">Studio Graffé</h1>
        <p class="font-label-caps text-label-caps text-on-surface-variant tracking-[0.2em] uppercase">Urban Elegance</p>
      </div>

      <!-- Form -->
      <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
        <div class="flex flex-col gap-8">
          <div class="space-y-6">
            <!-- Email -->
            <div class="relative flex flex-col floating-label-input">
              <%= f.email_field :email, autofocus: true, autocomplete: "email",
                    placeholder: " ",
                    class: "peer w-full bg-transparent border-0 border-b border-outline-variant py-2 focus:ring-0 focus:border-primary text-body-md transition-colors" %>
              <label class="absolute left-0 top-2 font-label-caps text-label-caps text-outline uppercase tracking-widest origin-left">
                Email
              </label>
            </div>

            <!-- Password -->
            <div class="relative flex flex-col floating-label-input">
              <%= f.password_field :password, autocomplete: "current-password",
                    placeholder: " ",
                    class: "peer w-full bg-transparent border-0 border-b border-outline-variant py-2 focus:ring-0 focus:border-primary text-body-md transition-colors" %>
              <label class="absolute left-0 top-2 font-label-caps text-label-caps text-outline uppercase tracking-widest origin-left">
                Contraseña
              </label>
            </div>

            <% if devise_mapping.rememberable? %>
              <div class="flex items-center gap-3">
                <%= f.check_box :remember_me, class: "rounded border-outline-variant text-primary focus:ring-primary" %>
                <%= f.label :remember_me, "Recordarme", class: "font-body-sm text-body-sm text-on-surface-variant" %>
              </div>
            <% end %>
          </div>

          <%= f.submit "Iniciar Sesión",
                class: "w-full bg-primary text-on-primary py-4 rounded-full font-label-caps text-label-caps uppercase tracking-widest transition-all duration-300 hover:scale-[1.02] hover:shadow-lg active:scale-95 cursor-pointer" %>
        </div>
      <% end %>

      <!-- Secondary Links -->
      <div class="flex flex-col items-center gap-4 border-t border-outline-variant/20 pt-8">
        <% if devise_mapping.recoverable? && controller_name != 'passwords' && controller_name != 'registrations' %>
          <%= link_to "¿Olvidaste tu contraseña?", new_password_path(resource_name),
                class: "font-label-caps text-label-caps text-on-surface-variant hover:text-primary transition-colors underline underline-offset-4 decoration-amber-200" %>
        <% end %>
        <p class="font-body-sm text-body-sm text-outline">
          ¿No tienes cuenta?
          <%= link_to "Regístrate", new_registration_path(resource_name),
                class: "text-primary font-medium hover:underline underline-offset-2" %>
        </p>
      </div>
    </div>

    <div class="mt-8 text-center opacity-40">
      <p class="font-label-caps text-[10px] tracking-[0.3em] uppercase text-outline">Exclusividad &amp; Precisión</p>
    </div>
  </main>
</div>
