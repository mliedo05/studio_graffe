<main class="pt-32 pb-24 px-6 max-w-2xl mx-auto">

  <div class="mb-10">
    <%= link_to profile_path, class: "flex items-center gap-2 text-on-surface-variant hover:text-primary transition-colors font-label-caps text-label-caps uppercase tracking-widest mb-6 inline-flex" do %>
      <span class="material-symbols-outlined text-[18px]">arrow_back</span>
      Volver a mi perfil
    <% end %>
    <h1 class="font-h1 text-h1 text-on-surface">Editar perfil</h1>
  </div>

  <%= form_with model: @user, url: profile_path, method: :patch, class: "space-y-6" do |f| %>
    <div class="bg-surface-container-lowest rounded-2xl border border-outline-variant/30 p-8">
      <h2 class="font-h2 text-h3 text-on-surface mb-6 pb-4 border-b border-outline-variant/20">Información personal</h2>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 mb-6">
        <div>
          <%= f.label :first_name, "Nombre", class: "block font-label-caps text-[11px] text-on-surface-variant uppercase tracking-widest mb-2" %>
          <%= f.text_field :first_name, class: "w-full bg-surface-container rounded-lg border border-outline-variant px-4 py-3 font-body-md text-on-surface focus:outline-none focus:border-primary transition-colors" %>
        </div>
        <div>
          <%= f.label :last_name, "Apellido", class: "block font-label-caps text-[11px] text-on-surface-variant uppercase tracking-widest mb-2" %>
          <%= f.text_field :last_name, class: "w-full bg-surface-container rounded-lg border border-outline-variant px-4 py-3 font-body-md text-on-surface focus:outline-none focus:border-primary transition-colors" %>
        </div>
      </div>

      <div class="mb-6">
        <%= f.label :phone, "Teléfono", class: "block font-label-caps text-[11px] text-on-surface-variant uppercase tracking-widest mb-2" %>
        <%= f.telephone_field :phone, class: "w-full bg-surface-container rounded-lg border border-outline-variant px-4 py-3 font-body-md text-on-surface focus:outline-none focus:border-primary transition-colors", placeholder: "+56 9 1234 5678" %>
      </div>

      <div>
        <%= f.label :email, "Email", class: "block font-label-caps text-[11px] text-on-surface-variant uppercase tracking-widest mb-2" %>
        <%= f.email_field :email, class: "w-full bg-surface-container rounded-lg border border-outline-variant px-4 py-3 font-body-md text-on-surface focus:outline-none focus:border-primary transition-colors" %>
      </div>
    </div>

    <div class="bg-surface-container-lowest rounded-2xl border border-outline-variant/30 p-8">
      <h2 class="font-h2 text-h3 text-on-surface mb-2 pb-4 border-b border-outline-variant/20">Cambiar contraseña</h2>
      <p class="font-body-sm text-on-surface-variant mb-6">Deja en blanco si no deseas cambiarla.</p>

      <div class="space-y-6">
        <div>
          <%= f.label :current_password, "Contraseña actual", class: "block font-label-caps text-[11px] text-on-surface-variant uppercase tracking-widest mb-2" %>
          <%= f.password_field :current_password, autocomplete: "current-password", class: "w-full bg-surface-container rounded-lg border border-outline-variant px-4 py-3 font-body-md text-on-surface focus:outline-none focus:border-primary transition-colors" %>
          <p class="font-body-sm text-[12px] text-on-surface-variant mt-1">Requerida para guardar cualquier cambio.</p>
        </div>
        <div>
          <%= f.label :password, "Nueva contraseña", class: "block font-label-caps text-[11px] text-on-surface-variant uppercase tracking-widest mb-2" %>
          <%= f.password_field :password, autocomplete: "new-password", class: "w-full bg-surface-container rounded-lg border border-outline-variant px-4 py-3 font-body-md text-on-surface focus:outline-none focus:border-primary transition-colors" %>
        </div>
        <div>
          <%= f.label :password_confirmation, "Confirmar nueva contraseña", class: "block font-label-caps text-[11px] text-on-surface-variant uppercase tracking-widest mb-2" %>
          <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "w-full bg-surface-container rounded-lg border border-outline-variant px-4 py-3 font-body-md text-on-surface focus:outline-none focus:border-primary transition-colors" %>
        </div>
      </div>
    </div>

    <% if @user.errors.any? %>
      <div class="bg-red-50 border border-red-200 rounded-xl p-4">
        <% @user.errors.full_messages.each do |msg| %>
          <p class="font-body-sm text-red-700">• <%= msg %></p>
        <% end %>
      </div>
    <% end %>

    <div class="flex justify-end gap-4">
      <%= link_to "Cancelar", profile_path, class: "px-6 py-3 border border-outline-variant text-on-surface-variant rounded-full font-label-caps text-label-caps uppercase tracking-widest hover:bg-surface-container transition-colors" %>
      <%= f.submit "Guardar cambios", class: "px-8 py-3 bg-primary text-on-primary rounded-full font-label-caps text-label-caps uppercase tracking-widest hover:scale-105 transition-transform cursor-pointer" %>
    </div>
  <% end %>

</main>
